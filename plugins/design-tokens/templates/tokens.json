{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Frankie design tokens — W3C Design Tokens Format Module 2025.10. Auto-generates Swift constants when iOS build starts (via Style Dictionary).",
  "color": {
    "category": {
      "body":    { "$value": "#C49A3D", "$type": "color", "$description": "CC-B — Body category accent (gold)" },
      "mind":    { "$value": "#3D8B8B", "$type": "color", "$description": "CC-M — Mind category accent (teal)" },
      "routine": { "$value": "#7B6E9E", "$type": "color", "$description": "CC-R — Routine category accent (purple)" }
    },
    "mood": {
      "light": {
        "happy":    { "$value": "#BBE0F2", "$type": "color", "$description": "MS-LH — Happy sky, light theme" },
        "content":  { "$value": "#C9DCC3", "$type": "color", "$description": "MS-LC — Content sky, light theme" },
        "bored":    { "$value": "#D6D3C8", "$type": "color", "$description": "MS-LB — Bored sky, light theme" },
        "sad":      { "$value": "#A9B5C4", "$type": "color", "$description": "MS-LS — Sad sky, light theme" },
        "critical": { "$value": "#7A5252", "$type": "color", "$description": "MS-LK — Critical sky, light theme" }
      },
      "dark": {
        "happy":    { "$value": "#1A3A4D", "$type": "color", "$description": "MS-DH — Happy sky, dark theme" },
        "content":  { "$value": "#1E362D", "$type": "color", "$description": "MS-DC — Content sky, dark theme" },
        "bored":    { "$value": "#2D2C2A", "$type": "color", "$description": "MS-DB — Bored sky, dark theme" },
        "sad":      { "$value": "#1A2233", "$type": "color", "$description": "MS-DS — Sad sky, dark theme" },
        "critical": { "$value": "#3D1F1F", "$type": "color", "$description": "MS-DK — Critical sky, dark theme" }
      }
    },
    "ui": {
      "background":     { "$value": "#FFF8F0", "$type": "color", "$description": "UI-BG — App background (cream)" },
      "text-primary":   { "$value": "#2C160E", "$type": "color", "$description": "UI-T1 — Primary text" },
      "text-secondary": { "$value": "#6F4627", "$type": "color", "$description": "UI-T2 — Secondary text" },
      "border":         { "$value": "#E7E5E4", "$type": "color", "$description": "UI-BD — Borders" },
      "accent":         { "$value": "#8B5E3C", "$type": "color", "$description": "UI-AC — Primary accent (brown)" },
      "night-sky":      { "$value": "#0B1026", "$type": "color", "$description": "UI-NK — Night sky overlay" },
      "muted-brown":    { "$value": "#8B5E3C", "$type": "color", "$description": "Header dividers, default checkbox borders" },
      "warm-grey":      { "$value": "#A8A29E", "$type": "color", "$description": "Time labels, info-date" },
      "item-bg":        { "$value": "#FFFCF5", "$type": "color", "$description": "Habbit-row backgrounds" },
      "bar-off-bg":     { "$value": "#F0EDE8", "$type": "color", "$description": "Empty bar segments" },
      "bar-off-border": { "$value": "#D9D2C9", "$type": "color", "$description": "Empty bar segment border" },
      "curtain":        { "$value": "#FFFFFF", "$type": "color", "$description": "Pull-down curtain surface" },
      "side-drawer":    { "$value": "#EFF3F8", "$type": "color", "$description": "Side drawer surface" }
    },
    "skill": {
      "chew":   { "$value": "#009688", "$type": "color", "$description": "Training skill — Chew (teal)" },
      "bark":   { "$value": "#FFA500", "$type": "color", "$description": "Training skill — Bark (orange)" },
      "jump":   { "$value": "#E91E63", "$type": "color", "$description": "Training skill — Jump (hot pink)" },
      "pull":   { "$value": "#D32F2F", "$type": "color", "$description": "Training skill — Pull (red)" },
      "run":    { "$value": "#4CAF50", "$type": "color", "$description": "Training skill — Run (green)" },
      "dig":    { "$value": "#A0826D", "$type": "color", "$description": "Training skill — Dig (tan)" },
      "steal":  { "$value": "#9C27B0", "$type": "color", "$description": "Training skill — Steal (purple)" },
      "toilet": { "$value": "#2196F3", "$type": "color", "$description": "Training skill — Toilet (blue)" },
      "chase":  { "$value": "#FF7043", "$type": "color", "$description": "Training skill — Chase (coral)" },
      "mud":    { "$value": "#6D4C41", "$type": "color", "$description": "Training skill — Mud (dark earth)" }
    },
    "status": {
      "age-active":   { "$value": "#A4000E", "$type": "color", "$description": "Age display active red" },
      "age-inactive": { "$value": "#C8C8C8", "$type": "color", "$description": "Age display inactive grey" },
      "locked":       { "$value": "#A8A8A8", "$type": "color", "$description": "Locked-state shield" },
      "tray-locked":  { "$value": "#C8C8C8", "$type": "color", "$description": "Locked-state tray" }
    }
  },
  "typography": {
    "family": { "$value": "system-ui", "$type": "fontFamily", "$description": "TY-F — SF Pro via -apple-system / .system in SwiftUI. Never reference 'SF Pro' by name." },
    "size": {
      "ring-side":      { "$value": "9px",  "$type": "dimension" },
      "ring-primary":   { "$value": "12px", "$type": "dimension" },
      "habit-name":     { "$value": "14px", "$type": "dimension" },
      "habit-time":     { "$value": "9px",  "$type": "dimension" },
      "habit-target":   { "$value": "12px", "$type": "dimension" },
      "habit-date":     { "$value": "9px",  "$type": "dimension" },
      "header-progress": { "$value": "13px","$type": "dimension" },
      "doggy-msg":      { "$value": "13px", "$type": "dimension" },
      "name-bar":       { "$value": "20px", "$type": "dimension" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" },
      "heavy":    { "$value": "800", "$type": "fontWeight" },
      "black":    { "$value": "900", "$type": "fontWeight" }
    }
  },
  "shadow": {
    "standard": {
      "$value": { "color": "rgba(0,0,0,0.12)", "offsetX": "0px", "offsetY": "2px", "blur": "3px", "spread": "0px" },
      "$type": "shadow",
      "$description": "DS-STD — used on cloud pill, nav bar, wake button, cards, modal cards"
    },
    "deep": {
      "$value": { "color": "rgba(0,0,0,0.18)", "offsetX": "0px", "offsetY": "2px", "blur": "3px", "spread": "0px" },
      "$type": "shadow",
      "$description": "Used on Training Badge shields and floating Add button"
    }
  },
  "spacing": {
    "phone": {
      "width":  { "$value": "390px", "$type": "dimension", "$description": "Phone container width" },
      "height": { "$value": "884px", "$type": "dimension", "$description": "Phone container height" }
    },
    "habbit-row": {
      "width":   { "$value": "358px", "$type": "dimension" },
      "padding": { "$value": "17.5px 12px", "$type": "spacing" }
    },
    "task-header": {
      "height":  { "$value": "32px", "$type": "dimension" }
    },
    "pd-bar": {
      "height":  { "$value": "90px", "$type": "dimension" }
    }
  },
  "radius": {
    "small":  { "$value": "2px",  "$type": "dimension" },
    "medium": { "$value": "8px",  "$type": "dimension" },
    "large":  { "$value": "10px", "$type": "dimension" },
    "xl":     { "$value": "16px", "$type": "dimension" },
    "circle": { "$value": "50%",  "$type": "dimension" }
  },
  "z-index": {
    "frankie":      { "$value": 1,  "$type": "number" },
    "doggy-feed":   { "$value": 2,  "$type": "number" },
    "vignette":     { "$value": 3,  "$type": "number" },
    "sleep-zzz":    { "$value": 4,  "$type": "number" },
    "wake-flash":   { "$value": 5,  "$type": "number" },
    "wake-button":  { "$value": 6,  "$type": "number" },
    "cloud-pill":   { "$value": 10, "$type": "number" },
    "ctrl-panel":   { "$value": 11, "$type": "number" },
    "topbar-icon":  { "$value": 12, "$type": "number" },
    "counter":      { "$value": 13, "$type": "number" },
    "habbit-panel": { "$value": 19, "$type": "number" },
    "split-handle": { "$value": 20, "$type": "number" },
    "task-header":  { "$value": 21, "$type": "number" },
    "side-drawer":  { "$value": 22, "$type": "number" },
    "pulldown":     { "$value": 25, "$type": "number" },
    "modal":        { "$value": 30, "$type": "number" }
  }
}
